# .env.example — Copy to /opt/srv-panel/.env and fill in real values
# install.sh creates this automatically. setup_powerdns.sh fills PDNS_API_KEY.

# Your VPS public IP address (required)
# Panel is always reachable at http://SERVER_IP/ after install
SERVER_IP=1.2.3.4

# Optional hostname for the panel UI (extra server_name next to the IP)
# Leave equal to SERVER_IP for IP-only access — no DNS needed
# Example with domain: panel.yourdomain.com
PANEL_DOMAIN=1.2.3.4

# PowerDNS REST API (set by setup_powerdns.sh — do not overwrite on update)
PDNS_URL=http://127.0.0.1:8081
PDNS_API_KEY=your_generated_api_key_here

# SQLite database path (must stay under app/ for updates to preserve it)
DB_PATH=/opt/srv-panel/app/panel.db

# Email for certbot/Let's Encrypt
CERTBOT_EMAIL=admin@yourdomain.com

# Nginx config directories
NGINX_SITES_AVAILABLE=/etc/nginx/sites-available
NGINX_SITES_ENABLED=/etc/nginx/sites-enabled
NGINX_WEBROOT=/var/www

# When true and process is not root, shell commands use sudo -n
# (requires /etc/sudoers.d/srv-panel from install.sh)
PRIVILEGED_SUDO=true

# Set to true for verbose logging during development
DEBUG=false

# Session cookie signing (install.sh / update.sh generate if missing)
# Do not commit real secrets. Rotate by changing this value (logs everyone out).
SECRET_KEY=change_me_to_a_long_random_string

# true only after the panel is served over HTTPS
SESSION_HTTPS_ONLY=false

# Session lifetime in seconds (default 7 days)
SESSION_MAX_AGE=604800
